ailable - using native date inputs\nimport {\n  BarChart,\n  Bar,\n  XAxis,\n  YAxis,\n  CartesianGrid,\n  Tooltip,\n  Legend,\n  ResponsiveContainer,\n  PieChart,\n  Pie,\n  Cell,\n  LineChart,\n  Line,\n} from 'recharts';\nimport { Download, FileText, Calendar, TrendingUp, Users, DollarSign } from 'lucide-react';\n\nconst COLORS = ['#14b8a6', '#3b82f6', '#8b5cf6', '#f97316', '#ef4444', '#10b981'];\n\n// Mock data for reports\nconst mockRevenueData = [\n  { month: 'Jan', revenue: 45000, expenses: 32000 },\n  { month: 'Feb', revenue: 52000, expenses: 35000 },\n  { month: 'Mar', revenue: 48000, expenses: 33000 },\n  { month: 'Apr', revenue: 61000, expenses: 38000 },\n  { month: 'May', revenue: 55000, expenses: 36000 },\n  { month: 'Jun', revenue: 67000, expenses: 40000 },\n];\n\nconst mockDepartmentData = [\n  { name: 'Cardiology', value: 35 },\n  { name: 'Neurology', value: 25 },\n  { name: 'Pediatrics', value: 20 },\n  { name: 'Orthopedics', value: 15 },\n  { name: 'General', value: 5 },\n];\n\nconst mockPatientData = [\n  { ageGroup: '0-17', count: 120 },\n  { ageGroup: '18-29', count: 250 },\n  { ageGroup: '30-49', count: 380 },\n  { ageGroup: '50-64', count: 290 },\n  { ageGroup: '65+', count: 180 },\n];\n\nconst Reports = () => {\n  // Date range state for future implementation\n  const [_dateRange, _setDateRange] = useState({ from: new Date(), to: new Date() });\n\n  const formatCurrency = (value: number) => {\n    return new Intl.NumberFormat('en-US', {\n      style: 'currency',\n      currency: 'USD',\n      minimumFractionDigits: 0,\n    }).format(value);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <motion.div\n        initial={{ opacity: 0, y: -20 }}\n        animate={{ opacity: 1, y: 0 }}\n        className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\"\n      >\n        <div>\n          <h1 className=\"text-2xl font-bold text-gray-900 dark:text-white\">Reports & Analytics</h1>\n          <p className=\"text-gray-500\">Comprehensive hospital reports and statistics</p>\n        </div>\n        <div className=\"flex gap-2\">\n          <Button variant=\"outline\">\n            <Calendar className=\"w-4 h-4 mr-2\" />\n            Date Range\n          </Button>\n          <Button className=\"bg-teal-500 hover:bg-teal-600 text-white\">\n            <Download className=\"w-4 h-4 mr-2\" />\n            Export PDF\n          </Button>\n        </div>\n      </motion.div>\n\n      {/* Summary Cards */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ delay: 0.1 }}\n        className=\"grid grid-cols-1 sm:grid-cols-4 gap-4\"\n      >\n        <Card>\n          <CardContent className=\"p-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-2 bg-teal-100 rounded-lg\">\n                <Users className=\"w-5 h-5 text-teal-600\" />\n              </div>\n              <div>\n                <p className=\"text-sm text-gray-500\">Total Patients</p>\n                <p className=\"text-2xl font-bold\">1,240</p>\n              </div>\n            </div>\n          </CardContent>\n        </Card>\n        <Card>\n          <CardContent className=\"p-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-2 bg-blue-100 rounded-lg\">\n                <TrendingUp className=\"w-5 h-5 text-blue-600\" />\n              </div>\n              <div>\n                <p className=\"text-sm text-gray-500\">Appointments</p>\n                <p className=\"text-2xl font-bold\">3,560</p>\n              </div>\n            </div>\n          </CardContent>\n        </Card>\n        <Card>\n          <CardContent className=\"p-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-2 bg-green-100 rounded-lg\">\n                <DollarSign className=\"w-5 h-5 text-green-600\" />\n              </div>\n              <div>\n                <p className=\"text-sm text-gray-500\">Revenue</p>\n                <p className=\"text-2xl font-bold\">$328K</p>\n              </div>\n            </div>\n          </CardContent>\n        </Card>\n        <Card>\n          <CardContent className=\"p-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"p-2 bg-purple-100 rounded-lg\">\n                <FileText className=\"w-5 h-5 text-purple-600\" />\n              </div>\n              <div>\n                <p className=\"text-sm text-gray-500\">Invoices</p>\n                <p className=\"text-2xl font-bold\">892</p>\n              </div>\n            </div>\n          </CardContent>\n        </Card>\n      </motion.div>\n\n      {/* Report Tabs */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ delay: 0.2 }}\n      >\n        <Tabs defaultValue=\"revenue\" className=\"space-y-4\">\n          <TabsList className=\"grid w-full grid-cols-4 lg:w-auto\">\n            <TabsTrigger value=\"revenue\">Revenue</TabsTrigger>\n            <TabsTrigger value=\"patients\">Patients</TabsTrigger>\n            <TabsTrigger value=\"appointments\">Appointments</TabsTrigger>\n            <TabsTrigger value=\"departments\">Departments</TabsTrigger>\n          </TabsList>\n\n          <TabsContent value=\"revenue\" className=\"space-y-4\">\n            <Card>\n              <CardHeader>\n                <CardTitle>Revenue vs Expenses</CardTitle>\n              </CardHeader>\n              <CardContent>\n                <ResponsiveContainer width=\"100%\" height={400}>\n                  <BarChart data={mockRevenueData}>\n                    <CartesianGrid strokeDasharray=\"3 3\" />\n                    <XAxis dataKey=\"month\" />\n                    <YAxis tickFormatter={(value) => `$${value / 1000}k`} />\n                    <Tooltip formatter={(value: number) => formatCurrency(value)} />\n                    <Legend />\n                    <Bar dataKey=\"revenue\" fill=\"#14b8a6\" name=\"Revenue\" radius={[4, 4, 0, 0]} />\n                    <Bar dataKey=\"expenses\" fill=\"#ef4444\" name=\"Expenses\" radius={[4, 4, 0, 0]} />\n                  </BarChart>\n                </ResponsiveContainer>\n              </CardContent>\n            </Card>\n          </TabsContent>\n\n          <TabsContent value=\"patients\" className=\"space-y-4\">\n            <Card>\n              <CardHeader>\n                <CardTitle>Patients by Age Group</CardTitle>\n              </CardHeader>\n              <CardContent>\n                <ResponsiveContainer width=\"100%\" height={400}>\n                  <BarChart data={mockPatientData}>\n                    <CartesianGrid strokeDasharray=\"3 3\" />\n                    <XAxis dataKey=\"ageGroup\" />\n                    <YAxis />\n                    <Tooltip />\n                    <Bar dataKey=\"count\" fill=\"#3b82f6\" radius={[4, 4, 0, 0]} />\n                  </BarChart>\n                </ResponsiveContainer>\n              </CardContent>\n            </Card>\n          </TabsContent>\n\n          <TabsContent value=\"appointments\" className=\"space-y-4\">\n            <Card>\n              <CardHeader>\n                <CardTitle>Monthly Appointment Trends</CardTitle>\n              </CardHeader>\n              <CardContent>\n                <ResponsiveContainer width=\"100%\" height={400}>\n                  <LineChart data={mockRevenueData}>\n                    <CartesianGrid strokeDasharray=\"3 3\" />\n                    <XAxis dataKey=\"month\" />\n                    <YAxis />\n                    <Tooltip />\n                    <Legend />\n                    <Line type=\"monotone\" dataKey=\"revenue\" stroke=\"#14b8a6\" strokeWidth={2} />\n                  </LineChart>\n                </ResponsiveContainer>\n              </CardContent>\n            </Card>\n          </TabsContent>\n\n          <TabsContent value=\"departments\" className=\"space-y-4\">\n            <Card>\n              <CardHeader>\n                <CardTitle>Revenue by Department</CardTitle>\n              </CardHeader>\n              <CardContent>\n                <ResponsiveContainer width=\"100%\" height={400}>\n                  <PieChart>\n                    <Pie\n                      data={mockDepartmentData}\n                      cx=\"50%\"\n                      cy=\"50%\"\n                      outerRadius={150}\n                      dataKey=\"value\"\n                      nameKey=\"name\"\n                      label\n                    >\n                      {mockDepartmentData.map((_entry, index) => (\n                        <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />\n                      ))}\n                    </Pie>\n                    <Tooltip />\n                    <Legend />\n                  </PieChart>\n                </ResponsiveContainer>\n              </CardContent>\n            </Card>\n          </TabsContent>\n        </Tabs>\n      </motion.div>\n    </div>\n  );\n};\n\nexport default Reports;","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Anis\\Documents\\Web Pages\\Hospital Manager\\app\\src\\pages\\Rooms.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":37,"column":48,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":37,"endColumn":51,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1251,1254],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1251,1254],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"