ing } = useSelector(\n    (state: RootState) => state.doctors\n  );\n  const [searchQuery, setSearchQuery] = useState('');\n\n  useEffect(() => {\n    fetchDoctors();\n  }, [currentPage]);\n\n  const fetchDoctors = async () => {\n    try {\n      const result = await doctorService.getDoctors({\n        page: currentPage,\n        limit: 10,\n        search: searchQuery,\n      });\n      dispatch(\n        setDoctors({\n          doctors: result.doctors,\n          total: result.pagination.total,\n          page: result.pagination.page,\n          totalPages: result.pagination.totalPages,\n        })\n      );\n    } catch (error) {\n      showError('Failed to load doctors');\n    }\n  };\n\n  const handleSearch = () => {\n    fetchDoctors();\n  };\n\n  const getStatusBadge = (status: string) => {\n    const variants: Record<string, 'default' | 'secondary' | 'destructive' | 'outline'> = {\n      ACTIVE: 'default',\n      INACTIVE: 'secondary',\n      ON_LEAVE: 'destructive',\n    };\n    return <Badge variant={variants[status] || 'default'}>{status}</Badge>;\n  };\n\n  const columns: ColumnDef<Doctor>[] = [\n    {\n      accessorKey: 'employeeId',\n      header: 'Employee ID',\n    },\n    {\n      accessorKey: 'user.fullName',\n      header: 'Name',\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center\">\n            <span className=\"font-medium text-teal-600\">\n              {row.original.user.firstName.charAt(0)}\n              {row.original.user.lastName.charAt(0)}\n            </span>\n          </div>\n          <div>\n            <p className=\"font-medium\">{row.original.user.fullName}</p>\n            <p className=\"text-sm text-gray-500\">{row.original.user.email}</p>\n          </div>\n        </div>\n      ),\n    },\n    {\n      accessorKey: 'specialization',\n      header: 'Specialization',\n    },\n    {\n      accessorKey: 'department.deptName',\n      header: 'Department',\n      cell: ({ row }) => row.original.department?.deptName || 'N/A',\n    },\n    {\n      accessorKey: 'experienceYears',\n      header: 'Experience',\n      cell: ({ row }) => `${row.original.experienceYears} years`,\n    },\n    {\n      accessorKey: 'rating',\n      header: 'Rating',\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-1\">\n          <Star className=\"w-4 h-4 text-yellow-400 fill-yellow-400\" />\n          <span>{row.original.rating.toFixed(1)}</span>\n        </div>\n      ),\n    },\n    {\n      accessorKey: 'status',\n      header: 'Status',\n      cell: ({ row }) => getStatusBadge(row.original.status),\n    },\n    {\n      id: 'actions',\n      header: 'Actions',\n      cell: ({ row }) => (\n        <DropdownMenu>\n          <DropdownMenuTrigger asChild>\n            <Button variant=\"ghost\" size=\"sm\">\n              <MoreVertical className=\"w-4 h-4\" />\n            </Button>\n          </DropdownMenuTrigger>\n          <DropdownMenuContent align=\"end\">\n            <DropdownMenuItem onClick={() => {\n              dispatch(setSelectedDoctor(row.original));\n              navigate(`/doctors/${row.original.doctorId}`);\n            }}>\n              <Users className=\"w-4 h-4 mr-2\" />\n              View Profile\n            </DropdownMenuItem>\n            <DropdownMenuItem onClick={() => navigate(`/doctors/${row.original.doctorId}/edit`)}>\n              <Edit className=\"w-4 h-4 mr-2\" />\n              Edit\n            </DropdownMenuItem>\n            <DropdownMenuItem onClick={() => navigate(`/doctors/${row.original.doctorId}/schedule`)}>\n              <Calendar className=\"w-4 h-4 mr-2\" />\n              Schedule\n            </DropdownMenuItem>\n          </DropdownMenuContent>\n        </DropdownMenu>\n      ),\n    },\n  ];\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <motion.div\n        initial={{ opacity: 0, y: -20 }}\n        animate={{ opacity: 1, y: 0 }}\n        className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\"\n      >\n        <div>\n          <h1 className=\"text-2xl font-bold text-gray-900 dark:text-white\">Doctors</h1>\n          <p className=\"text-gray-500\">Manage doctor profiles and schedules</p>\n        </div>\n        <Button\n          onClick={() => navigate('/doctors/new')}\n          className=\"bg-teal-500 hover:bg-teal-600 text-white\"\n        >\n          <Plus className=\"w-4 h-4 mr-2\" />\n          Add Doctor\n        </Button>\n      </motion.div>\n\n      {/* Search */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ delay: 0.1 }}\n        className=\"flex flex-col sm:flex-row gap-4\"\n      >\n        <div className=\"relative flex-1 max-w-md\">\n          <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" />\n          <Input\n            placeholder=\"Search doctors...\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            onKeyDown={(e) => e.key === 'Enter' && handleSearch()}\n            className=\"pl-10\"\n          />\n        </div>\n        <Button variant=\"outline\" onClick={handleSearch}>\n          Search\n        </Button>\n      </motion.div>\n\n      {/* Data Table */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ delay: 0.2 }}\n      >\n        <DataTable\n          columns={columns}\n          data={doctors}\n          pagination={{\n            page: currentPage,\n            limit: 10,\n            total: totalDoctors,\n            totalPages,\n          }}\n          onPageChange={(page) => dispatch(setDoctors({ doctors, total: totalDoctors, page, totalPages }))}\n          isLoading={isLoading}\n        />\n      </motion.div>\n    </div>\n  );\n};\n\nex