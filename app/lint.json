State, type AppDispatch } from '@/store';\nimport { setPatients, setSelectedPatient, deletePatient } from '@/store/slices/patientSlice';\nimport { patientService } from '@/services/patientService';\nimport { useToast } from '@/hooks/useToast';\nimport { DataTable } from '@/components/common/DataTable';\nimport { Button } from '@/components/ui/button';\nimport { Input } from '@/components/ui/input';\nimport { Badge } from '@/components/ui/badge';\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n} from '@/components/ui/dialog';\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuTrigger,\n} from '@/components/ui/dropdown-menu';\nimport { Plus, Search, MoreVertical, Edit, Trash2, FileText, Calendar } from 'lucide-react';\nimport type { Patient } from '@/types';\nimport type { ColumnDef } from '@tanstack/react-table';\n\nconst Patients = () => {\n  const navigate = useNavigate();\n  const dispatch = useDispatch<AppDispatch>();\n  const { showSuccess, showError } = useToast();\n  const { patients, totalPatients, currentPage, totalPages, isLoading } = useSelector(\n    (state: RootState) => state.patients\n  );\n  const [searchQuery, setSearchQuery] = useState('');\n  const [deleteDialogOpen, setDeleteDialogOpen] = useState(false);\n  const [patientToDelete, setPatientToDelete] = useState<Patient | null>(null);\n\n  useEffect(() => {\n    fetchPatients();\n  }, [currentPage]);\n\n  const fetchPatients = async () => {\n    try {\n      const result = await patientService.getPatients({\n        page: currentPage,\n        limit: 10,\n        search: searchQuery,\n      });\n      dispatch(\n        setPatients({\n          patients: result.patients,\n          total: result.pagination.total,\n          page: result.pagination.page,\n          totalPages: result.pagination.totalPages,\n        })\n      );\n    } catch (error) {\n      showError('Failed to load patients');\n    }\n  };\n\n  const handleSearch = () => {\n    fetchPatients();\n  };\n\n  const handleDelete = async () => {\n    if (!patientToDelete) return;\n    \n    try {\n      await patientService.deletePatient(patientToDelete.patientId);\n      dispatch(deletePatient(patientToDelete.patientId));\n      showSuccess('Patient deleted successfully');\n    } catch (error: any) {\n      showError(error.response?.data?.message || 'Failed to delete patient');\n    } finally {\n      setDeleteDialogOpen(false);\n      setPatientToDelete(null);\n    }\n  };\n\n  const getStatusBadge = (status: string) => {\n    const variants: Record<string, 'default' | 'secondary' | 'destructive' | 'outline'> = {\n      INPATIENT: 'default',\n      OUTPATIENT: 'secondary',\n      DISCHARGED: 'outline',\n    };\n    return <Badge variant={variants[status] || 'default'}>{status}</Badge>;\n  };\n\n  const columns: ColumnDef<Patient>[] = [\n    {\n      accessorKey: 'patientCode',\n      header: 'Patient ID',\n      cell: ({ row }) => <span className=\"font-medium\">{row.original.patientCode}</span>,\n    },\n    {\n      accessorKey: 'fullName',\n      header: 'Name',\n      cell: ({ row }) => (\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center\">\n            <span className=\"text-sm font-medium text-teal-600\">\n              {row.original.firstName.charAt(0)}\n            </span>\n          </div>\n          <div>\n            <p className=\"font-medium\">{row.original.fullName}</p>\n            <p className=\"text-sm text-gray-500\">{row.original.email}</p>\n          </div>\n        </div>\n      ),\n    },\n    {\n      accessorKey: 'gender',\n      header: 'Gender',\n      cell: ({ row }) => (\n        <span className=\"capitalize\">{row.original.gender?.toLowerCase()}</span>\n      ),\n    },\n    {\n      accessorKey: 'phone',\n      header: 'Phone',\n    },\n    {\n      accessorKey: 'assignedDoctor',\n      header: 'Assigned Doctor',\n      cell: ({ row }) => row.original.assignedDoctor?.name || 'Not Assigned',\n    },\n    {\n      accessorKey: 'status',\n      header: 'Status',\n      cell: ({ row }) => getStatusBadge(row.original.status),\n    },\n    {\n      id: 'actions',\n      header: 'Actions',\n      cell: ({ row }) => (\n        <DropdownMenu>\n          <DropdownMenuTrigger asChild>\n            <Button variant=\"ghost\" size=\"sm\">\n              <MoreVertical className=\"w-4 h-4\" />\n            </Button>\n          </DropdownMenuTrigger>\n          <DropdownMenuContent align=\"end\">\n            <DropdownMenuItem onClick={() => {\n              dispatch(setSelectedPatient(row.original));\n              navigate(`/patients/${row.original.patientId}`);\n            }}>\n              <FileText className=\"w-4 h-4 mr-2\" />\n              View Details\n            </DropdownMenuItem>\n            <DropdownMenuItem onClick={() => navigate(`/patients/${row.original.patientId}/edit`)}>\n              <Edit className=\"w-4 h-4 mr-2\" />\n              Edit\n            </DropdownMenuItem>\n            <DropdownMenuItem onClick={() => navigate(`/patients/${row.original.patientId}/appointments`)}>\n              <Calendar className=\"w-4 h-4 mr-2\" />\n              Appointments\n            </DropdownMenuItem>\n            <DropdownMenuItem\n              className=\"text-red-600\"\n              onClick={() => {\n                setPatientToDelete(row.original);\n                setDeleteDialogOpen(true);\n              }}\n            >\n              <Trash2 className=\"w-4 h-4 mr-2\" />\n              Delete\n            </DropdownMenuItem>\n          </DropdownMenuContent>\n        </DropdownMenu>\n      ),\n    },\n  ];\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <motion.div\n        initial={{ opacity: 0, y: -20 }}\n        animate={{ opacity: 1, y: 0 }}\n        className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\"\n      >\n        <div>\n          <h1 className=\"text-2xl font-bold text-gray-900 dark:text-white\">Patient Directory</h1>\n          <p className=\"text-gray-500\">Manage and view all patient records</p>\n        </div>\n        <Button\n          onClick={() => navigate('/patients/new')}\n          className=\"bg-teal-500 hover:bg-teal-600 text-white\"\n        >\n          <Plus className=\"w-4 h-4 mr-2\" />\n          Add Patient\n        </Button>\n      </motion.div>\n\n      {/* Search and Filters */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ delay: 0.1 }}\n        className=\"flex flex-col sm:flex-row gap-4\"\n      >\n        <div className=\"relative flex-1 max-w-md\">\n          <Search className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" />\n          <Input\n            placeholder=\"Search patients...\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            onKeyDown={(e) => e.key === 'Enter' && handleSearch()}\n            className=\"pl-10\"\n          />\n        </div>\n        <Button variant=\"outline\" onClick={handleSearch}>\n          Search\n        </Button>\n      </motion.div>\n\n      {/* Data Table */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ delay: 0.2 }}\n      >\n        <DataTable\n          columns={columns}\n          data={patients}\n          pagination={{\n            page: currentPage,\n            limit: 10,\n            total: totalPatients,\n            totalPages,\n          }}\n          onPageChange={(page) => dispatch(setPatients({ patients, total: totalPatients, page, totalPages }))}\n          isLoading={isLoading}\n        />\n      </motion.div>\n\n      {/* Delete Confirmation Dialog */}\n      <Dialog open={deleteDialogOpen} onOpenChange=